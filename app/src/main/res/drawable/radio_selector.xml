<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected state -->
    <item android:state_checked="true">
        <shape>
            <solid android:color="#EDE0FF"/>
            <stroke android:width="2dp" android:color="#6C35DE"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
    <!-- Default state -->
    <item>
        <shape>
            <solid android:color="#F8F5FF"/>
            <stroke android:width="1dp" android:color="#D4C8F5"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>
</selector>
